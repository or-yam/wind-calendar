{
  "name": "wind-calendar",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "vercel dev",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest run",
    "check": "pnpm run fmt:check && pnpm run lint && tsc -b && vitest run",
    "start": "vite",
    "preview": "vite preview"
  },
  "dependencies": {
    "ics": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.9",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vercel": "^50.25.4",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
