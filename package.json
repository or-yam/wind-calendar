{
  "name": "wind-calendar",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "vercel dev",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:ci": "oxlint --format=github",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest run",
    "check": "pnpm run fmt:check && pnpm run lint && tsc -b && vitest run",
    "start": "vite",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ics": "^3.8.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.9",
    "@vitejs/plugin-react": "^5.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "~5.9.3",
    "vercel": "^50.25.4",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern --write",
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "bash -c 'tsc -b --noEmit'"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
